*.py[cod]
*$py.class

# 虚拟环境
.venv/
venv/
ENV/

# 环境变量（最重要！绝对不能提交）
.env
.env.local
.env.*

# 日志文件
*.log
logs/

# 打包和分发
dist/
build/
*.egg-info/
*.egg

# 测试和覆盖率
.pytest_cache/
.coverage
htmlcov/

# ------------------------------
